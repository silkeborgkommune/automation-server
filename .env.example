# Automation Server — Environment Configuration
# Copy to .env and customize for your environment

# ─── Common ────────────────────────────────────────
TZ=Europe/Copenhagen

# ─── Database ──────────────────────────────────────
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=ats_password
POSTGRES_DB=ats

# ─── Workers ──────────────────────────────────────
ATS_TOKEN=                          # Leave blank for development
ATS_URL=http://api:8000             # Internal Docker network URL
ATS_CAPABILITIES=playwright

# ─── Deployment ───────────────────────────────────
# Standalone (ATS owns port 80):
#   HTTP_PORT=80                    (default)
#
# Behind reverse proxy (Caddy, Traefik, etc.):
#   HTTP_PORT=8080                  (or any free port)
#   Point your proxy to http://localhost:8080
